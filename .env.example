# ============================================================
# Wayfare — environment variables reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Database ────────────────────────────────────────────────
# PostgreSQL connection string (Replit provisions one automatically).
# Format: postgres://user:password@host:port/dbname
DATABASE_URL=postgres://user:password@localhost:5432/wayfare

# ── Session ─────────────────────────────────────────────────
# Long random secret for Express session signing.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_random_64_char_hex_string

# ── Object Storage (Replit App Storage / GCS) ───────────────
# Set by Replit when you enable App Storage.
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=private
PUBLIC_OBJECT_SEARCH_PATHS=public

# ── AI (OpenAI via Replit AI Integrations) ──────────────────
# Provided automatically when you enable the OpenAI integration in Replit.
OPENAI_API_KEY=

# ── Plaid (bank linking — optional) ─────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
# sandbox | development | production
PLAID_ENV=sandbox

# ── GoCardless (bank linking — optional) ─────────────────────
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=

# ── API server port (set by Replit artifact runner) ─────────
PORT=5000
